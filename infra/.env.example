# Backend core
DATABASE_URL=postgres://mitrascore:mitrascore@db:5432/mitrascore
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGIN_REGEXES=^http://localhost:\d+$,^http://127\.0\.0\.1:\d+$
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_SESSION_COOKIE_SECURE=0
DJANGO_CSRF_COOKIE_SECURE=0
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_PRELOAD=0

# Demo-safe default. Set false only when Azure credentials below are configured.
USE_MOCK_AI=true

# Azure AI Vision through Azure AI services
AZURE_AI_VISION_ENDPOINT=https://<your-ai-services-name>.cognitiveservices.azure.com
AZURE_AI_VISION_KEY=<your-azure-ai-services-key>

# Azure AI Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://<your-document-intelligence-name>.cognitiveservices.azure.com
AZURE_DOCUMENT_INTELLIGENCE_KEY=<your-document-intelligence-key>

# Optional private Azure Blob evidence storage. Local file storage remains default.
USE_AZURE_BLOB_STORAGE=false
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=<private-container-name>

# Safe upload constraints
MAX_EVIDENCE_UPLOAD_BYTES=8388608
ALLOWED_EVIDENCE_EXTENSIONS=jpg,jpeg,png,pdf,txt
ALLOWED_EVIDENCE_MIME_TYPES=image/jpeg,image/png,application/pdf,text/plain,application/octet-stream

# Future optional extensions. Not required for this MVP.
AZURE_LANGUAGE_ENDPOINT=
AZURE_LANGUAGE_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX_NAME=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api
